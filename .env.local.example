# ================================================
# FixFlow — Environment Variables
# ================================================
# 1. Copy ไฟล์นี้เป็น .env.local
# 2. ใส่ค่าจาก Supabase Dashboard → Settings → API
# ================================================

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service Role Key (ใช้สร้าง/ลบ user ฝั่ง server เท่านั้น — ห้าม expose ให้ browser)
# หาได้ที่: Supabase Dashboard → Settings → API → service_role (secret)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
